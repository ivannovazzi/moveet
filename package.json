{
  "name": "moveet",
  "version": "0.0.10",
  "description": "Real-time vehicle fleet simulator on OpenStreetMap road networks",
  "author": "Ivan Novazzi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannovazzi/moveet.git"
  },
  "private": true,
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo test",
    "dev:sim": "turbo dev --filter=@moveet/simulator",
    "dev:ui": "turbo dev --filter=@moveet/ui",
    "dev:adapter": "turbo dev --filter=@moveet/adapter",
    "type-check": "turbo type-check",
    "test:commitlint": "node --test commitlint.config.test.mjs",
    "test:repo": "vitest run --config vitest.repo-policy.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.10.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "overrides": {
    "flatted": "3.4.2"
  },
  "packageManager": "npm@11.12.0"
}
