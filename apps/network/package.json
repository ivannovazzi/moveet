{
  "name": "@moveet/network",
  "version": "0.1.0",
  "description": "CLI tool for downloading and preparing OSM road network data",
  "type": "module",
  "bin": {
    "network": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsc --watch --noEmit",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^13.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@moveet/eslint-config": "*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
