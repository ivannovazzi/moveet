{
  "name": "@moveet/network",
  "version": "0.1.0",
  "private": true,
  "description": "Internal CLI tool for downloading and preparing OSM road network data (not published, versioned independently of the monorepo release)",
  "type": "module",
  "bin": {
    "network": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsc --watch --noEmit",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@moveet/eslint-config": "*",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
