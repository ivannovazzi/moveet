{
  "name": "@moveet/simulator",
  "version": "0.0.10",
  "description": "Vehicle location simulator for fleet management systems using real road networks from OpenStreetMap",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run build:worker",
    "dev": "tsx watch src/index.ts",
    "dev:gateway": "tsx watch src/ws-gateway.ts",
    "start": "NODE_ENV=production node ./dist/index.js",
    "start:gateway": "NODE_ENV=production node ./dist/ws-gateway.js",
    "build:worker": "node scripts/build-worker.mjs",
    "build": "tsc && npm run build:worker",
    "type-check": "tsc --noEmit",
    "pretest": "npm run build:worker",
    "test": "vitest run",
    "pretest:ci": "npm run build:worker",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:bench": "vitest bench --run src/__tests__/PerfBudget.bench.ts"
  },
  "author": "Ivan Novazzi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannovazzi/moveet.git",
    "directory": "apps/simulator"
  },
  "keywords": [
    "fleet-management",
    "vehicle-simulation",
    "location-tracking",
    "openstreetmap",
    "geospatial",
    "routing",
    "pathfinding"
  ],
  "dependencies": {
    "@moveet/server-kit": "*",
    "@moveet/shared-types": "*",
    "@scalar/express-api-reference": "^0.10.7",
    "@turf/turf": "^7.3.4",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
