{
  "name": "@moveet/simulator",
  "version": "0.0.6",
  "description": "Vehicle location simulator for fleet management systems using real road networks from OpenStreetMap",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "NODE_ENV=production node ./dist/index.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\""
  },
  "author": "Ivan Novazzi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannovazzi/moveet.git",
    "directory": "apps/simulator"
  },
  "keywords": [
    "fleet-management",
    "vehicle-simulation",
    "location-tracking",
    "openstreetmap",
    "geospatial",
    "routing",
    "pathfinding"
  ],
  "dependencies": {
    "@moveet/shared-types": "*",
    "@scalar/express-api-reference": "^0.9.4",
    "@turf/turf": "^7.3.4",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@moveet/eslint-config": "*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "yaml": "^2.8.2"
  }
}
