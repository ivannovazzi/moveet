# Server Configuration
PORT=5010

# Simulation Update Configuration
# How often to update vehicle positions (in milliseconds)
UPDATE_INTERVAL=500

# Vehicle Speed Configuration (km/h)
MIN_SPEED=20
MAX_SPEED=60

# Vehicle Dynamics
ACCELERATION=5
DECELERATION=7
TURN_THRESHOLD=30

# Speed randomization factor (0.0 to 1.0)
# Controls how much individual vehicle speeds vary from target
SPEED_VARIATION=0.1

# Heat zone speed reduction factor (0.0 to 1.0)
# Lower values mean vehicles move slower in heat zones
HEATZONE_SPEED_FACTOR=0.5

# Number of default vehicles when running without adapter
VEHICLE_COUNT=70

# Adapter Configuration
# URL of the external adapter service
ADAPTER_URL=http://localhost:5011

# Timeout for adapter sync requests (in milliseconds)
SYNC_ADAPTER_TIMEOUT=5000

# GeoJSON Data Path
# Path to the road network GeoJSON file
GEOJSON_PATH=./data/network.geojson
