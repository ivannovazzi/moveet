# Server Configuration
PORT=5010

# Simulation Update Configuration
# How often to update vehicle positions (in milliseconds)
UPDATE_INTERVAL=500

# Vehicle Speed Configuration (km/h)
MIN_SPEED=20
MAX_SPEED=60

# Vehicle Dynamics
ACCELERATION=5
DECELERATION=7
TURN_THRESHOLD=30

# Speed randomization factor (0.0 to 1.0)
# Controls how much individual vehicle speeds vary from target
SPEED_VARIATION=0.1

# Heat zone speed reduction factor (0.0 to 1.0)
# Lower values mean vehicles move slower in heat zones
HEATZONE_SPEED_FACTOR=0.5

# Number of default vehicles when running without adapter
VEHICLE_COUNT=70

# Vehicle type distribution override (JSON).
# When empty, uses built-in weighted distribution: 60% car, 15% truck, 12% motorcycle, 10% bus, 3% ambulance
# VEHICLE_TYPES={"car":50,"truck":10,"bus":7,"motorcycle":3}

# Adapter Configuration
# URL of the external adapter service
ADAPTER_URL=http://localhost:5011

# Timeout for adapter sync requests (in milliseconds)
SYNC_ADAPTER_TIMEOUT=5000

# How often (ms) vehicle positions are pushed to the adapter / downstream sinks.
# 0 = follow UPDATE_INTERVAL. Runtime-adjustable via the "Publish Interval" control.
ADAPTER_SYNC_INTERVAL=0

# GeoJSON Data Path
# Path to the road network GeoJSON file
GEOJSON_PATH=./data/network.geojson

# Persistence Configuration (SQLite state snapshots)
# Enable/disable SQLite persistence layer
PERSISTENCE_ENABLED=false
# Auto-save interval in seconds
PERSISTENCE_INTERVAL=30
# Restore simulation state from latest snapshot on startup
RESTORE_STATE=false
# Path to the SQLite state database
STATE_DB_PATH=data/state.db

# Observability
# How often (ms) the analytics snapshot is broadcast to WS clients and persisted
ANALYTICS_INTERVAL=5000
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# WebSocket Fan-out Transport
# How vehicle/broadcast messages reach WS clients:
#   inprocess (default) — fan out to in-process WS clients on the sim thread
#   redis               — publish onto a Redis pub/sub channel for a separate
#                         ws-gateway process to fan out (scales clients off the
#                         sim thread). Requires REDIS_URL.
WS_TRANSPORT=inprocess
# Redis connection URL. Required when WS_TRANSPORT=redis and by the gateway.
REDIS_URL=
# Redis pub/sub channel the simulator publishes to and the gateway subscribes to
WS_PUBSUB_CHANNEL=moveet:ws:broadcast
# Port the standalone WS gateway (start:gateway) listens on
WS_GATEWAY_PORT=5020
