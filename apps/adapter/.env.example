# Port for the adapter service
PORT=5011

# Allowed CORS origins (comma-separated). Set to * to allow all origins.
# Default: * (all origins allowed)
# CORS_ORIGINS=http://localhost:5010,http://localhost:5012

# Source: static | graphql | rest | mysql | postgres
# Default: static (generates fake vehicles)
SOURCE_TYPE=static
SOURCE_CONFIG={"count":20}

# Sinks: comma-separated list of sink types
# Available: graphql, rest, redpanda, redis, webhook, console
SINK_TYPES=console
SINK_CONSOLE_CONFIG={"verbose":false}

# Example: GraphQL source + Redpanda sink
# SOURCE_TYPE=graphql
# SOURCE_CONFIG={"url":"http://localhost:4001/graphql","token":"your-token","query":"{ vehicles { id callsign latitude longitude } }","vehiclePath":"vehicles"}
# SINK_TYPES=redpanda
# SINK_REDPANDA_CONFIG={"brokers":"localhost:19092","topic":"dispatch.vehicle.positions"}

# Example: feed the external trajectory-engine (pure-GPS telemetry schema).
# "format":"trajectory" emits {ts,deviceId,lat,lon,speed,heading,altitude,accuracy,ignition}
# on the engine's input topic. altitude/accuracy are not simulated, so they fall
# back to the configurable defaults below; ignition is derived from speed.
# Requires the simulator to run with ADAPTER_URL set so it forwards speed/heading.
# SINK_TYPES=redpanda
# SINK_REDPANDA_CONFIG={"brokers":"suite_redpanda:9092","topic":"trajectory.telemetry.raw","format":"trajectory","defaultAltitude":0,"defaultAccuracy":5}

# Example: drive the REAL fleet from the connector (dispatch-cc-consumer) so
# telemetry is keyed by real device ids the trajectory engine can join. This is
# pure config — the generic "rest" source pulls the connector's fleet-roster
# endpoint, maps each assignment's deviceId to the simulated entity id, and
# captures deviceType/vehicleId as metadata; the redpanda "trajectory" sink keys
# telemetry by that deviceId and emits deviceType from the metadata.
#
# Each assignment in the roster is one simulated entity (id = deviceId). Position
# is optional: add fieldMap.lat/lng if the endpoint returns coordinates,
# otherwise the simulator seeds them. Metadata flows end-to-end to the payload.
# SOURCE_TYPE=rest
# SOURCE_CONFIG={"url":"http://suite_connector:3002/api/fleet/roster","vehiclePath":"assignments","fieldMap":{"id":"deviceId"},"metadataMap":{"deviceType":"deviceType","vehicleId":"vehicleId"}}
# SINK_TYPES=redpanda
# SINK_REDPANDA_CONFIG={"brokers":"suite_redpanda:9092","topic":"trajectory.telemetry.raw","format":"trajectory","keyField":"id","defaultAltitude":0,"defaultAccuracy":5}
#
# Equivalent with an explicit payloadTemplate (use to add/rename fields):
# SINK_REDPANDA_CONFIG={"brokers":"suite_redpanda:9092","topic":"trajectory.telemetry.raw","keyField":"id","payloadTemplate":{"ts":"ts","deviceId":"id","deviceType":"metadata.deviceType","lat":"lat","lon":"lon","speed":"speed","heading":"heading","altitude":"altitude","accuracy":"accuracy","ignition":"ignition"}}
