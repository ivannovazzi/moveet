# Port for the adapter service
PORT=5011

# Allowed CORS origins (comma-separated). Set to * to allow all origins.
# Default: * (all origins allowed)
# CORS_ORIGINS=http://localhost:5010,http://localhost:5012

# Source: static | graphql | rest | mysql | postgres
# Default: static (generates fake vehicles)
SOURCE_TYPE=static
SOURCE_CONFIG={"count":20}

# Sinks: comma-separated list of sink types
# Available: graphql, rest, redpanda, redis, webhook, console
SINK_TYPES=console
SINK_CONSOLE_CONFIG={"verbose":false}

# Example: GraphQL source + Redpanda sink
# SOURCE_TYPE=graphql
# SOURCE_CONFIG={"url":"http://localhost:4001/graphql","token":"your-token","query":"{ vehicles { id callsign latitude longitude } }","vehiclePath":"vehicles"}
# SINK_TYPES=redpanda
# SINK_REDPANDA_CONFIG={"brokers":"localhost:19092","topic":"dispatch.vehicle.positions"}

# Example: feed the external trajectory-engine (pure-GPS telemetry schema).
# "format":"trajectory" emits {ts,vehicleId,lat,lon,speed,heading,altitude,accuracy,ignition}
# on the engine's input topic. altitude/accuracy are not simulated, so they fall
# back to the configurable defaults below; ignition is derived from speed.
# Requires the simulator to run with ADAPTER_URL set so it forwards speed/heading.
# SINK_TYPES=redpanda
# SINK_REDPANDA_CONFIG={"brokers":"suite_redpanda:9092","topic":"trajectory.telemetry.raw","format":"trajectory","defaultAltitude":0,"defaultAccuracy":5}
