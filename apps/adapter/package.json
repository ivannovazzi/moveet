  },
  "dependencies": {
    "@kafkajs/confluent-schema-registry": "^4.0.8",
    "@moveet/server-kit": "*",
    "@moveet/shared-types": "*",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^17.0.1",
    "graphql-request": "^7.4.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
